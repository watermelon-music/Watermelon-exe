{
  "name": "watermelon",
  "version": "1.1.0",
  "description": "Watermelon Music — Windows Desktop App",
  "main": "dist-electron/main.js",
  "author": "Watermelon Music",
  "private": true,
  "scripts": {
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build && electron-builder --win",
    "build:dir": "vite build && electron-builder --win --dir",
    "release": "vite build && electron-builder --win --publish always",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "electron-updater": "^6.3.4",
    "framer-motion": "^11.3.0",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "youtube-dl-exec": "^3.1.9",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.0.0",
    "electron": "^32.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.watermelon.music",
    "productName": "Watermelon",
    "icon": "public/icon.png",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      "bin/**/*"
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "watermelon-music",
      "repo": "Watermelon-exe"
    }
  }
}
